<div class="container">
  <div class="dashboard-layout">
    
    <!-- Sidebar -->
    <aside class="sidebar-card">
      <h2 class="condo-card-title"><%= current_condominium.name %></h2>
      <p class="condo-card-address">📍 <%= current_condominium.address.presence || t(".no_address") %></p>

      <% if current_condominium.whatsapp_group_link.present? %>
        <p class="condo-card-whatsapp">
          <a href="<%= current_condominium.whatsapp_group_link %>" target="_blank" rel="noopener" class="whatsapp-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" fill="currentColor"/>
            </svg>
            WhatsApp Group
          </a>
        </p>
      <% end %>

      <% if current_user.admin? %>
        <p class="condo-card-settings">
          <%= link_to t(".condo_settings"), edit_condominium_path, class: "settings-link" %>
        </p>
      <% end %>

      <nav class="tab-nav">
        <%= link_to dashboard_path(tab: 'discussions'), class: "tab-link #{@tab == 'discussions' ? 'active' : ''}" do %>
          <%= t(".discussions_tab") %>
        <% end %>
        
        <%= link_to dashboard_path(tab: 'announcements'), class: "tab-link #{@tab == 'announcements' ? 'active' : ''}" do %>
          <%= t(".announcements_tab") %>
        <% end %>
        
        <%= link_to dashboard_path(tab: 'services'), class: "tab-link #{@tab == 'services' ? 'active' : ''}" do %>
          <%= t(".services_tab") %>
        <% end %>
      </nav>
      
      <% if Rails.env.development? %>
        <div style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
          <span style="display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.5rem; text-transform: uppercase; font-weight: 700;"><%= t(".sandbox_mode") %></span>
          <%= link_to t(".switch_persona"), new_session_path, class: "btn btn-secondary", style: "width: 100%; font-size: 0.8rem; padding: 0.5rem;" %>
        </div>
      <% end %>
    </aside>

    <!-- Main Content Area -->
    <main>
      
      <% if @tab == 'discussions' %>
        <!-- TAB: DISCUSSIONS -->
        <div class="feed-header">
          <h1 class="feed-title"><%= t(".resident_discussions") %></h1>
        </div>

        <!-- Create new topic form -->
        <div class="creator-card">
          <h3 class="creator-title"><%= t(".share_something") %></h3>
          <%= form_with model: @new_topic, url: topics_path, local: true do |form| %>
            <%= form.hidden_field :topic_type, value: 'discussion' %>
            
            <div class="form-group">
              <%= form.text_field :title, required: true, placeholder: t(".title_placeholder"), class: "form-input" %>
            </div>
            
            <div class="form-group">
              <%= form.text_area :content, required: true, rows: 3, placeholder: t(".content_placeholder"), class: "form-input" %>
            </div>
            
            <div style="display: flex; justify-content: flex-end;">
              <%= form.submit t(".post_discussion"), class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>

        <!-- Topics Feed -->
        <% if @topics.any? %>
          <% @topics.each do |topic| %>
            <div class="post-card">
              <div class="upvote-container">
                <% upvoted = topic.upvotes.exists?(user: current_user) %>
                <%= button_to topic_upvote_path(topic), method: :post, class: "upvote-btn #{upvoted ? 'upvoted' : ''}" do %>
                  ▲
                <% end %>
                <span class="upvote-count"><%= topic.upvotes_count %></span>
              </div>
              <div class="post-main">
                <div class="post-meta">
                  <%= t(".posted_by") %> <span class="post-author"><%= topic.user.full_name %></span>
                  <span class="badge badge-<%= topic.user.role %>"><%= t("roles.#{topic.user.role}") %></span>
                  <span>•</span>
                  <span><%= time_ago_in_words(topic.created_at) %> <%= t(".ago") %></span>
                </div>
                <h2 class="post-title"><%= link_to topic.title, topic_path(topic) %></h2>
                <p class="post-body-snippet"><%= truncate(topic.content, length: 180) %></p>
                <div class="post-footer">
                  <%= link_to topic_path(topic), class: "post-footer-link" do %>
                    💬 <%= topic.comments.count %> <%= t(".comments") %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
            <%= t(".no_discussions") %>
          </div>
        <% end %>

      <% elsif @tab == 'announcements' %>
        <!-- TAB: ANNOUNCEMENTS -->
        <div class="feed-header">
          <h1 class="feed-title"><%= t(".management_announcements") %></h1>
          <span class="badge badge-announcement" style="padding: 0.4rem 0.8rem; font-size: 0.75rem;"><%= t(".official_only") %></span>
        </div>

        <!-- Create new announcement (Admins only) -->
        <% if current_user.admin? %>
          <div class="creator-card" style="border-left: 4px solid var(--warning);">
            <h3 class="creator-title" style="color: var(--warning);"><%= t(".publish_heading") %></h3>
            <%= form_with model: @new_topic, url: topics_path, local: true do |form| %>
              <%= form.hidden_field :topic_type, value: 'announcement' %>
              
              <div class="form-group">
                <%= form.text_field :title, required: true, placeholder: t(".announcement_title_placeholder"), class: "form-input" %>
              </div>
              
              <div class="form-group">
                <%= form.text_area :content, required: true, rows: 4, placeholder: t(".announcement_content_placeholder"), class: "form-input" %>
              </div>
              
              <div style="display: flex; justify-content: flex-end;">
                <%= form.submit t(".publish_announcement"), class: "btn btn-primary", style: "background: var(--warning); color: black;" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="creator-card" style="background: rgba(245, 158, 11, 0.03); border: 1px dashed rgba(245, 158, 11, 0.2); text-align: center; color: var(--warning); font-size: 0.9rem;">
            <%= t(".announcements_readonly") %>
          </div>
        <% end %>

        <!-- Announcements Feed -->
        <% if @topics.any? %>
          <% @topics.each do |announcement| %>
            <div class="post-card" style="border-left: 3px solid var(--warning);">
              <div class="upvote-container">
                <% upvoted = announcement.upvotes.exists?(user: current_user) %>
                <%= button_to topic_upvote_path(announcement), method: :post, class: "upvote-btn #{upvoted ? 'upvoted' : ''}" do %>
                  ▲
                <% end %>
                <span class="upvote-count"><%= announcement.upvotes_count %></span>
              </div>
              <div class="post-main">
                <div class="post-meta">
                  <%= t(".published_by") %> <span class="post-author"><%= announcement.user.full_name %></span>
                  <span class="badge badge-admin"><%= t("roles.admin") %></span>
                  <span>•</span>
                  <span><%= time_ago_in_words(announcement.created_at) %> <%= t(".ago") %></span>
                </div>
                <h2 class="post-title"><%= link_to announcement.title, topic_path(announcement) %></h2>
                <p class="post-body-snippet" style="color: var(--text-primary);"><%= truncate(announcement.content, length: 250) %></p>
                <div class="post-footer">
                  <%= link_to topic_path(announcement), class: "post-footer-link" do %>
                    💬 <%= announcement.comments.count %> <%= t(".comments") %>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        <% else %>
          <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
            <%= t(".no_announcements") %>
          </div>
        <% end %>

      <% elsif @tab == 'services' %>
        <!-- TAB: LOCAL SERVICES -->
        <div class="feed-header">
          <h1 class="feed-title"><%= t(".trusted_services") %></h1>
        </div>

        <!-- Recommend new service form -->
        <div class="creator-card">
          <h3 class="creator-title"><%= t(".recommend_service") %></h3>
          <%= form_with model: @new_service, url: service_listings_path, local: true do |form| %>
            
            <div class="condo-switcher-grid" style="gap: 1rem; margin-bottom: 1rem;">
              <div class="form-group" style="margin-bottom: 0;">
                <%= form.label :title, t(".provider_name_label"), class: "form-label" %>
                <%= form.text_field :title, required: true, placeholder: t(".provider_name_placeholder"), class: "form-input" %>
              </div>
              
              <div class="form-group" style="margin-bottom: 0;">
                <%= form.label :category, t(".category_label"), class: "form-label" %>
                <%= form.text_field :category, required: true, placeholder: t(".category_placeholder"), class: "form-input" %>
              </div>
            </div>

            <div class="form-group">
              <%= form.label :contact_info, t(".contact_info_label"), class: "form-label" %>
              <%= form.text_field :contact_info, required: true, placeholder: t(".contact_info_placeholder"), class: "form-input" %>
            </div>
            
            <div class="form-group">
              <%= form.label :description, t(".reason_label"), class: "form-label" %>
              <%= form.text_area :description, required: true, rows: 2, placeholder: t(".reason_placeholder"), class: "form-input" %>
            </div>
            
            <div style="display: flex; justify-content: flex-end;">
              <%= form.submit t(".submit_recommendation"), class: "btn btn-primary" %>
            </div>
          <% end %>
        </div>

        <!-- Services Feed -->
        <% if @services.any? %>
          <% @services.each do |service| %>
            <div class="service-card">
              <div class="service-left">
                <span class="service-category"><%= service.category %></span>
                <h2 class="service-title"><%= service.title %></h2>
                <p class="service-desc"><%= service.description %></p>
                <div class="service-contact">
                  <span>📞 <strong><%= t(".contact_label") %></strong> <%= service.contact_info %></span>
                  <span>•</span>
                  <span><%= t(".recommended_by") %> <strong><%= service.user.full_name %></strong></span>
                </div>
              </div>
              
              <div class="service-vouch">
                <%= button_to vouch_service_listing_path(service), method: :post, class: "btn btn-vouch" do %>
                  <%= t(".vouch") %>
                <% end %>
                <span style="font-size: 0.8rem; font-weight: 700; color: var(--success);"><%= service.upvotes_count %> <%= t(".vouches") %></span>
              </div>
            </div>
          <% end %>
        <% else %>
          <div style="text-align: center; padding: 3rem; color: var(--text-secondary);">
            <%= t(".no_services") %>
          </div>
        <% end %>

      <% end %>

    </main>
  </div>
</div>
