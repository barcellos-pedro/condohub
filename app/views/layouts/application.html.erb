<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "CondoHub — The Resident Portal" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="CondoHub">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Include custom styling after base app styling %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "custom", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% if authenticated? %>
      <header class="app-header">
        <a href="<%= root_path %>" class="logo">
          CondoHub <span class="logo-sub">MVP</span>
        </a>
        
        <div class="user-nav-card">
          <div class="user-nav-info">
            <div class="user-nav-name"><%= current_user.full_name %></div>
            <div class="user-nav-meta">
              <span class="badge badge-<%= current_user.role %>"><%= current_user.role %></span>
              <span>•</span>
              <strong style="color: var(--primary-accent);"><%= current_condominium.name %></strong>
            </div>
          </div>
          
          <button data-controller="theme" data-action="theme#toggle" class="btn btn-secondary" style="padding: 0.4rem 0.6rem; font-size: 1rem; line-height: 1;">
            <span data-theme-target="icon">☀️</span>
          </button>

          <%= button_to "Log Out", session_path, method: :delete, class: "btn btn-danger", style: "padding: 0.4rem 0.8rem; font-size: 0.8rem;" %>
        </div>
      </header>
    <% end %>

    <% if flash.any? %>
      <div class="flash-container">
        <% flash.each do |type, message| %>
          <div class="flash flash-<%= type %>">
            <span><%= message %></span>
          </div>
        <% end %>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
