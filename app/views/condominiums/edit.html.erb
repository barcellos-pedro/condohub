<div class="container">
  <div class="settings-card">
    <h1 class="settings-title"><%= t(".title") %></h1>
    <p class="settings-subtitle"><%= t(".subtitle") %></p>

    <%= form_with model: @condominium, url: condominium_path, method: :patch, local: true do |form| %>
      <div class="form-group">
        <%= form.label :name, t(".name_label"), class: "form-label" %>
        <%= form.text_field :name, required: true, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= form.label :address, t(".address_label"), class: "form-label" %>
        <%= form.text_field :address, class: "form-input", placeholder: t(".address_placeholder") %>
      </div>

      <div class="form-group">
        <%= form.label :whatsapp_group_link, t(".whatsapp_label"), class: "form-label" %>
        <%= form.url_field :whatsapp_group_link, class: "form-input", placeholder: "https://chat.whatsapp.com/..." %>
        <p class="form-hint"><%= t(".whatsapp_hint") %></p>
      </div>

      <div style="display: flex; gap: 1rem; margin-top: 1.5rem;">
        <%= form.submit t(".save"), class: "btn btn-primary" %>
        <%= link_to t(".cancel"), dashboard_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
